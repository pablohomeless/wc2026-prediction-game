# Environment Variables - Copy this to .env.local for local development

# Database (Azure PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@SERVER.postgres.database.azure.com:5432/wc2026?sslmode=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-32-char-secret-here"

# Encryption key for email PII (must be exactly 32 characters)
EMAIL_ENCRYPTION_KEY="your-32-character-encryption-key!!"

# Email (SMTP - e.g., Gmail, SendGrid, Azure Communication Services SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
SMTP_FROM="WC 2026 Porra <porra@yourdomain.com>"

# App URL (used for email links)
APP_URL="http://localhost:3000"

# Football results API (optional - for automatic results fetching)
# Supported: football-data.org (free tier available)
FOOTBALL_API_KEY="your-api-key"
FOOTBALL_API_BASE="https://api.football-data.org/v4"
# Competition ID for WC 2026 in football-data.org (update when known)
WC2026_COMPETITION_ID="2000"

# Admin email (must match encrypted DB record)
ADMIN_EMAIL="pablosanchez@microsoft.com"
